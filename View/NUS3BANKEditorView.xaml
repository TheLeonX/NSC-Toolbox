                                              Value="{Binding Randomizer_unk1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Increment="1"
                                              VerticalContentAlignment="Center"
                                              VerticalAlignment="Stretch"
                                              HorizontalAlignment="Stretch"
                                              FontFamily="{StaticResource NarutoFont}"
                                              Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                              Background="{DynamicResource Toolbox_button_background_color_1}"
                                              BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                              BorderThickness="1"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Randomizer unk2:" Grid.Column="0" VerticalAlignment="Center"/>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                              MinHeight="30"
                                              Value="{Binding Randomizer_unk2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Increment="1"
                                              VerticalContentAlignment="Center"
                                              VerticalAlignment="Stretch"
                                              HorizontalAlignment="Stretch"
                                              FontFamily="{StaticResource NarutoFont}"
                                              Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                              Background="{DynamicResource Toolbox_button_background_color_1}"
                                              BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                              BorderThickness="1"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Randomizer unk3:" Grid.Column="0" VerticalAlignment="Center"/>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                              MinHeight="30"
                                              Value="{Binding Randomizer_unk3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Increment="1"
                                              VerticalContentAlignment="Center"
                                              VerticalAlignment="Stretch"
                                              HorizontalAlignment="Stretch"
                                              FontFamily="{StaticResource NarutoFont}"
                                              Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                              Background="{DynamicResource Toolbox_button_background_color_1}"
                                              BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                              BorderThickness="1"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Randomizer unk4:" Grid.Column="0" VerticalAlignment="Center"/>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                              MinHeight="30"
                                              Value="{Binding Randomizer_unk4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Increment="1"
                                              VerticalContentAlignment="Center"
                                              VerticalAlignment="Stretch"
                                              HorizontalAlignment="Stretch"
                                              FontFamily="{StaticResource NarutoFont}"
                                              Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                              Background="{DynamicResource Toolbox_button_background_color_1}"
                                              BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                              BorderThickness="1"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Randomizer unk5:" Grid.Column="0" VerticalAlignment="Center"/>
                                        <xctk:DoubleUpDown Grid.Column="1"
                                              MinHeight="30"
                                              Value="{Binding Randomizer_unk5, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Increment="1"
                                              VerticalContentAlignment="Center"
                                              VerticalAlignment="Stretch"
                                              HorizontalAlignment="Stretch"
                                              FontFamily="{StaticResource NarutoFont}"
                                              Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                              Background="{DynamicResource Toolbox_button_background_color_1}"
                                              BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                              BorderThickness="1"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Randomizer unk6:" Grid.Column="0" VerticalAlignment="Center"/>
                                        <xctk:IntegerUpDown Grid.Column="1"
                                                        MinHeight="30"
                                                        Value="{Binding Randomizer_unk6, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        Increment="1"
                                                        VerticalContentAlignment="Center"
                                                        VerticalAlignment="Stretch"
                                                        HorizontalAlignment="Stretch"
                                                        FontFamily="{StaticResource NarutoFont}"
                                                        Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                                        Background="{DynamicResource Toolbox_button_background_color_1}"
                                                        BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                                        BorderThickness="1"/>
                                    </Grid>
                                    <TextBlock Text="Randomizer entries" FontWeight="Bold" Margin="0,6,0,6"/>
                                    <DataGrid ItemsSource="{Binding RandomizerList}"
                                              SelectedItem="{Binding SelectedRandomizer}"
                                              SelectedIndex="{Binding SelectedRandomizerIndex}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                    SelectionMode="Single"
                                    CanUserSortColumns="False"
                                  Height="280">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="ID" MinWidth="80">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <xctk:IntegerUpDown Value="{Binding ID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Increment="1"
                                                               MinHeight="26"
                                                               VerticalContentAlignment="Center"
                                                               HorizontalAlignment="Stretch"
                                                               FontFamily="{StaticResource NarutoFont}"
                                                               Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                                               Background="{DynamicResource Toolbox_button_background_color_1}"
                                                               BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                                               BorderThickness="1"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="Unk" MinWidth="80">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <xctk:IntegerUpDown Value="{Binding Unk, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Increment="1" MinHeight="26"
                                                               VerticalContentAlignment="Center"
                                                               HorizontalAlignment="Stretch"
                                                               FontFamily="{StaticResource NarutoFont}"
                                                               Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                                               Background="{DynamicResource Toolbox_button_background_color_1}"
                                                               BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                                               BorderThickness="1"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="PlayChance" MinWidth="100" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <xctk:DoubleUpDown Value="{Binding PlayChance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Increment="1" MinHeight="26"
                                                              VerticalContentAlignment="Center"
                                                              HorizontalAlignment="Stretch"
                                                              FontFamily="{StaticResource NarutoFont}"
                                                              Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                                              Background="{DynamicResource Toolbox_button_background_color_1}"
                                                              BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                                              BorderThickness="1"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTemplateColumn Header="Tone" MinWidth="200" Width="*">
                                                <!-- preview (non-edit) shows name resolved from ToneList and ToneID -->
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock VerticalAlignment="Center" Padding="4,2">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource IndexToNameConverter}">
                                                                    <Binding Path="ToneID" />
                                                                    <Binding Path="DataContext.ToneList" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>

                                                <!-- editing: ComboBox bound to ToneList, SelectedIndex bound to ToneID -->
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <ComboBox
        ItemsSource="{Binding DataContext.ToneList, RelativeSource={RelativeSource AncestorType=DataGrid}}"
        SelectedIndex="{Binding ToneID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        DisplayMemberPath="Name"
        VerticalContentAlignment="Center"
        HorizontalAlignment="Stretch"
        MinHeight="26"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <Grid Grid.Row="3" x:Name="RandomizerEntryButtons">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="5"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="5"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Button Command="{Binding AddRandomizerEntryCommand}" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  Background="{DynamicResource Toolbox_button_background_color_2}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}">
                                            <TextBlock Text="{DynamicResource m_AddEntry}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="16" TextWrapping="WrapWithOverflow" TextAlignment="Center"/>
                                        </Button>
                                        <Button Command="{Binding DuplicateRandomizerEntryCommand}" Grid.Row="2" Grid.Column="0"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  Background="{DynamicResource Toolbox_button_background_color_2}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}">
                                            <TextBlock Text="{DynamicResource m_DupEntry}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="16" TextWrapping="WrapWithOverflow" TextAlignment="Center"/>
                                        </Button>
                                        <Button Command="{Binding DeleteRandomizerEntryCommand}" Grid.Row="2" Grid.Column="2"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  Background="{DynamicResource Toolbox_button_background_color_3}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}">
                                            <TextBlock Text="{DynamicResource m_DeleteEntry}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="16" TextWrapping="WrapWithOverflow" TextAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <!-- Empty slot -->
                                <StackPanel x:Name="EmptyPanel" Orientation="Vertical" Visibility="{Binding EmptySlotVisibility, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="2">
                                    <TextBlock Text="Empty Slot" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="No sound data available for this entry." TextWrapping="Wrap" Width="240" TextAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="105"/>
                            </Grid.RowDefinitions>
                            <DataGrid Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="1"
                                  x:Name="SoundsDataGrid"
                                  ItemsSource="{Binding ToneList}"
                                  SelectedItem="{Binding SelectedTone, Mode=TwoWay}"
                                  SelectedIndex="{Binding SelectedToneIndex, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="False"
                                  FontFamily="{StaticResource NarutoFont}"
                                  Margin="8">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="#" Width="48" IsReadOnly="True" CanUserSort="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock HorizontalAlignment="Center">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource DataGridItemIndexConverter}">
                                                            <!-- Передаём коллекцию отображаемых элементов DataGrid.Items -->
                                                            <Binding RelativeSource="{RelativeSource AncestorType=DataGrid}" Path="Items"/>
                                                            <!-- Текущий элемент DataContext -->
                                                            <Binding />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Name"  CanUserSort="False" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NameEmptyConverter}}" Width="*"/>
                                    <DataGridTextColumn Header="Type" CanUserSort="False" IsReadOnly="True"  Binding="{Binding Type, Converter={StaticResource SoundTypeConverter}}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="5"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Button Command="{Binding CopyTonePropertiesCommand}" Grid.Row="0" Grid.Column="0"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  Background="{DynamicResource Toolbox_button_background_color_2}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}">
                                    <TextBlock Text="{DynamicResource m_nus3bankEditor_copy}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="16" TextWrapping="WrapWithOverflow" TextAlignment="Center"/>
                                </Button>
                                <Button Command="{Binding PasteTonePropertiesCommand}" Grid.Row="0" Grid.Column="2"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  Background="{DynamicResource Toolbox_button_background_color_2}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}">
                                    <TextBlock Text="{DynamicResource m_nus3bankEditor_paste}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="16" TextWrapping="WrapWithOverflow" TextAlignment="Center"/>
                                </Button>
                                <Button Command="{Binding AddToneEntryCommand}" Grid.Row="2" Grid.Column="0"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  Background="{DynamicResource Toolbox_button_background_color_2}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}">
                                    <TextBlock Text="{DynamicResource m_AddEntry}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="16" TextWrapping="WrapWithOverflow" TextAlignment="Center"/>
                                </Button>
                                <Button Command="{Binding DeleteToneEntryCommand}" Grid.Row="2" Grid.Column="2"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  Background="{DynamicResource Toolbox_button_background_color_3}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}">
                                    <TextBlock Text="{DynamicResource m_DeleteEntry}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="16" TextWrapping="WrapWithOverflow" TextAlignment="Center"/>
                                </Button>
                            </Grid>
                        </Grid>
                    </Grid>

                </TabItem>
                <TabItem Header="Sound File Info">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Vertical">
                            <Label Grid.Column="2"  Grid.Row="9" Grid.ColumnSpan="3" HorizontalAlignment="Left" VerticalAlignment="Center"  FontFamily="{StaticResource NarutoFont}" Content="{DynamicResource m_nus3bankEditor_fileid}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="14"/>
                            <xctk:IntegerUpDown Height="30" Grid.Column="2"  Grid.Row="10" Value="{Binding FileID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="3" Increment="1" Minimum="0" VerticalContentAlignment="Center" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}" Background="{DynamicResource Toolbox_button_background_color_1}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}" BorderThickness="1"/>
                            <Label Grid.Column="2"  Grid.Row="0" Grid.ColumnSpan="3"  HorizontalAlignment="Left" VerticalAlignment="Center"  FontFamily="{StaticResource NarutoFont}" Content="{DynamicResource m_nus3bankEditor_filename}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="14"/>
                            <TextBox MaxLength="31" Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="3"  Text="{Binding FileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Foreground="{DynamicResource Toolbox_button_text_color_1}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" FontFamily="{StaticResource NarutoFont}" Background="{DynamicResource Toolbox_button_background_color_1}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}" BorderThickness="1" />

                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Groups">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="50"/>
                        </Grid.RowDefinitions>
                        <!-- Список групп -->
                        <DataGrid x:Name="GroupEntriesDataGrid"
                              Grid.Column="0"
                              ItemsSource="{Binding GroupList}"
                              SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                              SelectedIndex="{Binding SelectedGroupIndex, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                                  
                             SelectionMode="Single"
                              IsReadOnly="False"
                              FontFamily="{StaticResource NarutoFont}"
                              Margin="8,0,0,0">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="#" Width="48" IsReadOnly="True" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource DataGridItemIndexConverter}">
                                                        <!-- Передаём коллекцию отображаемых элементов DataGrid.Items -->
                                                        <Binding RelativeSource="{RelativeSource AncestorType=DataGrid}" Path="Items"/>
                                                        <!-- Текущий элемент DataContext -->
                                                        <Binding />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Name"  CanUserSort="False" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTemplateColumn Header="Unk1" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <xctk:IntegerUpDown
                                                Value="{Binding Unk1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Increment="1"
                                                Minimum="0"
                                                VerticalContentAlignment="Center"
                                                VerticalAlignment="Stretch"
                                                HorizontalAlignment="Stretch"
                                                FontFamily="{StaticResource NarutoFont}"
                                                Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                                Background="{DynamicResource Toolbox_button_background_color_1}"
                                                BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                                BorderThickness="1"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Unk1" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <xctk:IntegerUpDown
                                                Value="{Binding Unk2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Increment="1"
                                                Minimum="0"
                                                VerticalContentAlignment="Center"
                                                VerticalAlignment="Stretch"
                                                HorizontalAlignment="Stretch"
                                                FontFamily="{StaticResource NarutoFont}"
                                                Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                                Background="{DynamicResource Toolbox_button_background_color_1}"
                                                BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                                BorderThickness="1"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Command="{Binding AddGrpEntryCommand}" Grid.Row="0" Grid.Column="0"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  Background="{DynamicResource Toolbox_button_background_color_2}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}">
                                <TextBlock Text="{DynamicResource m_AddEntry}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="16" TextWrapping="WrapWithOverflow" TextAlignment="Center"/>
                            </Button>
                            <Button Command="{Binding DeleteGrpEntryCommand}" Grid.Row="0" Grid.Column="2"  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"  Background="{DynamicResource Toolbox_button_background_color_3}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}">
                                <TextBlock Text="{DynamicResource m_DeleteEntry}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="16" TextWrapping="WrapWithOverflow" TextAlignment="Center"/>
                            </Button>
                        </Grid>
                        <!-- Разделитель -->
                        <Border Grid.Column="1" Background="Transparent" Width="8"/>

                        <!-- Список записей выбранной группы -->
                    </Grid>
                </TabItem>


                
            </TabControl>
            
            
        </Grid>
    </Viewbox>
</Window>
