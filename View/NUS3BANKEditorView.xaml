<Window x:Class="NSC_Toolbox.View.NUS3BANKEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NSC_Toolbox.View"
        xmlns:converter="clr-namespace:NSC_Toolbox.Converter"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"  
        xmlns:xcdg="http://schemas.xceed.com/wpf/xaml/datagrid"
        xmlns:gif="http://wpfanimatedgif.codeplex.com" xmlns:Controls="clr-namespace:NSC_Toolbox.Controls"
        mc:Ignorable="d"
        xmlns:properties="clr-namespace:NSC_Toolbox.Properties"
        Width="1230" Height="950"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="{DynamicResource m_nus3bankEditor}">
    <Window.Background>
        <ImageBrush ImageSource="{DynamicResource ResourceKey=TitleBackground}" ViewboxUnits="RelativeToBoundingBox" ViewportUnits="RelativeToBoundingBox" Stretch="UniformToFill" />
    </Window.Background>
    <Window.Resources>
        <converter:DataGridItemIndexConverter x:Key="DataGridItemIndexConverter" />
        <converter:GroupIndexToNameConverter x:Key="GroupIndexToNameConverter"/>
        <converter:AlternationToIndexConverter x:Key="AlternationToIndexConverter"/>
        <converter:SoundTypeConverter x:Key="SoundTypeConverter" />
        <converter:NameEmptyConverter x:Key="NameEmptyConverter" />
        <converter:NameEmptyConverter x:Key="EntryTypeToVisibilityConverter" />
        <converter:SoundDataPreviewConverter x:Key="SoundDataPreviewConverter"/>
        <converter:ChannelTypeConverter x:Key="ChannelTypeConverter"/>
        <converter:IndexToNameConverter x:Key="IndexToNameConverter"/>
        <Style x:Key="IconCircleButton" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="{TemplateBinding Width}"
                          Height="{TemplateBinding Height}"
                          RenderTransformOrigin="0.5,0.5"
                          Background="{TemplateBinding Background}">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="ContainerScale" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>

                            <Path x:Name="CirclePath"
                              Data="{StaticResource Circle}"
                              Stretch="Uniform"
                              Fill="Transparent"
                              Stroke="{DynamicResource Toolbox_button_text_color_1}"
                              StrokeThickness="1"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">
                                <Path.Effect>
                                    <DropShadowEffect x:Name="CircleShadow" BlurRadius="0" ShadowDepth="0" Opacity="0" Color="Black"/>
                                </Path.Effect>
                            </Path>

                            <Path x:Name="IconPath"
                              Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                              Stretch="Uniform"
                              Fill="{DynamicResource Toolbox_button_text_color_1}"
                              Width="22"
                              Height="22"
                                  Margin="6,6,0,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                                <Path.RenderTransform>
                                    <ScaleTransform x:Name="IconScale" ScaleX="0.7" ScaleY="0.7"/>
                                </Path.RenderTransform>
                            </Path>

                            <ContentPresenter Visibility="Collapsed"/>
                        </Grid>

                        <ControlTemplate.Resources>
                            <Storyboard x:Key="ClickFeedback">
                                
                            </Storyboard>
                        </ControlTemplate.Resources>

                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContainerScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.08" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="ContainerScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.08" Duration="0:0:0.15" />
                                           
                                            <DoubleAnimation Storyboard.TargetName="CirclePath"
                                                         Storyboard.TargetProperty="StrokeThickness"
                                                         To="1.8" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="CircleShadow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="8" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="CircleShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.35" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContainerScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="ContainerScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.15" />
                                            
                                            <DoubleAnimation Storyboard.TargetName="CirclePath"
                                                         Storyboard.TargetProperty="StrokeThickness"
                                                         To="1" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="CircleShadow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="0" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="CircleShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContainerScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.92" Duration="0:0:0.08" />
                                            <DoubleAnimation Storyboard.TargetName="ContainerScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.92" Duration="0:0:0.08" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContainerScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.08" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="ContainerScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.08" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <!-- Keyboard focus -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CircleShadow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="6" Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="CircleShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.28" Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CircleShadow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="0" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="CircleShadow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <!-- Click feedback -->
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard Storyboard="{StaticResource ClickFeedback}"/>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Viewbox Stretch="{Binding Source={x:Static properties:Settings.Default}, Path=StretchMode}">
        <Grid Width="1500" Height="1200"  Background="{DynamicResource Toolbox_button_background_color_1}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="5"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
            </Grid.RowDefinitions>
            <Menu Grid.Column="0" Grid.ColumnSpan="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}">
                <MenuItem Header="{DynamicResource m_File}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}">
                    <MenuItem Command="{Binding OpenFileCommand}" Header="{DynamicResource m_OpenFile}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}"/>
                    <MenuItem Command="{Binding SaveFileCommand}" Header="{DynamicResource m_SaveFile}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}"/>
                    <MenuItem Command="{Binding SaveFileAsCommand}" Header="{DynamicResource m_SaveAsFile}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}"/>
                </MenuItem>
                <MenuItem Header="{DynamicResource m_nus3bankEditor_tools}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}">
                    <MenuItem Command="{Binding ExtractAllRawCommand}" Header="{DynamicResource m_nus3bankEditor_extract_raw}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}"/>
                    <MenuItem Command="{Binding ExtractAllWavCommand}" Header="{DynamicResource m_nus3bankEditor_extract_wav}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}"/>
                    <MenuItem Command="{Binding ExtractAllRawWithIndexCommand}" Header="{DynamicResource m_nus3bankEditor_extract_raw2}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}"/>
                    <MenuItem Command="{Binding ExtractAllWavWithIndexCommand}" Header="{DynamicResource m_nus3bankEditor_extract_wav2}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}"/>
                    <MenuItem Command="{Binding BatchImportRawCommand}" Header="{DynamicResource m_nus3bankEditor_import_raw}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}"/>
                    <MenuItem Command="{Binding BatchImportBNSFCommand}" Header="{DynamicResource m_nus3bankEditor_import_bnsf}" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}"/>
                </MenuItem>
                <MenuItem Command="{Binding ExportSeparamCommand}" Header="Export separam" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}"/>
            </Menu>
            <Border Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="14" Grid.RowSpan="50" BorderBrush="White" BorderThickness="0,1,0,0"/>
            <TabControl Grid.Row="2" Grid.Column="1" Margin="0" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}"  BorderThickness="0,2,0,0" BorderBrush="Black">
                <TabControl.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </TabControl.Background>
                <TabItem Header="Sound Data">
                    <!-- Оригинальный внутренний Grid помещён сюда -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="4*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="5"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="14" Grid.RowSpan="50" BorderBrush="White" BorderThickness="1,1,1,0"/>
                        <Border Grid.Column="2" Grid.Row="3" Grid.ColumnSpan="1" Grid.RowSpan="50" BorderBrush="White" BorderThickness="1,0,0,0"/>
                        <Border Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="14" Grid.RowSpan="50" BorderBrush="White" BorderThickness="0,1,0,0"/>
                        <Grid Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Margin="8">
                            <StackPanel Orientation="Vertical">
                                <DockPanel LastChildFill="True" VerticalAlignment="Stretch">
                                    <!-- Left: transport + entry buttons -->
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,50,0">
                                        <Button Style="{StaticResource IconCircleButton}" Tag="{StaticResource Play}" Command="{Binding PlaySoundCommand}" ToolTip="Play" Margin="12,0,0,0" />
                                        <!--<Button Style="{StaticResource IconCircleButton}" Tag="{StaticResource Pause}" Command="{Binding PauseCommand}" ToolTip="Pause" Margin="12,0,0,0"/>-->
                                        <Button Style="{StaticResource IconCircleButton}" Tag="{StaticResource Stop}" Command="{Binding StopSoundCommand}" ToolTip="Stop" Margin="12,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical" DockPanel.Dock="Left" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,0,8,0">
                                        <TextBlock Grid.Row="0"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               FontFamily="{StaticResource NarutoFont}"
                                               Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                               FontSize="14">
                                            <TextBlock.Text>
                                                <Binding Path="SelectedTone.SampleRate" StringFormat="Sample Rate: {0} Hz" />
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Grid.Row="0"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               FontFamily="{StaticResource NarutoFont}"
                                               Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                               FontSize="14">
                                            <TextBlock.Text>
                                                <Binding Path="SelectedTone.SoundData" StringFormat="Format: {0}" Converter="{StaticResource SoundDataPreviewConverter}" />
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Grid.Row="0"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           FontFamily="{StaticResource NarutoFont}"
                                           Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                           FontSize="14">
                                            <TextBlock.Text>
                                                <Binding Path="SelectedTone.TotalSamples1" StringFormat="Total Samples: {0}" />
                                            </TextBlock.Text>
                                        </TextBlock>

                                    </StackPanel>
                                    <TextBlock Grid.Row="0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        FontFamily="{StaticResource NarutoFont}"
                                        Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                        FontSize="14">
                                        <TextBlock.Text>
                                            <Binding Path="SelectedTone.ChannelType" StringFormat="Channel Type: {0}"  Converter="{StaticResource ChannelTypeConverter}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <!-- Right: volume slider -->
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="Volume" VerticalAlignment="Center" Margin="0,0,12,0" FontFamily="{StaticResource NarutoFont}" Foreground="{DynamicResource Toolbox_button_text_color_1}"/>
                                        <Slider x:Name="VolumeSlider" Width="200" Minimum="0" Maximum="1" Value="{Binding SoundVolume, Mode=TwoWay}" SmallChange="0.01" LargeChange="0.1" />
                                    </StackPanel>
                                </DockPanel>

                                <!-- Time output (current / total) -->
                                <TextBlock  x:Name="TimeTextBlock"
                               Text="{Binding TimeDisplay, FallbackValue=--/--}"
                               HorizontalAlignment="Left"
                               Margin="4,8,0,0"
                               FontFamily="{StaticResource NarutoFont}"
                               Foreground="{DynamicResource Toolbox_button_text_color_1}" />
                            </StackPanel>
                        </Grid>
                        <!-- Правый столбец: детали выбранной записи (с xctk контролами) -->
                        <Grid Grid.Row="1" Grid.Column="3" Grid.RowSpan="3" Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="3*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <Label Grid.Column="6"  Grid.Row="0" Grid.ColumnSpan="1" HorizontalAlignment="Left" VerticalAlignment="Center"  FontFamily="{StaticResource NarutoFont}" Content="{DynamicResource m_nus3bankEditor_soundType}" Foreground="{DynamicResource Toolbox_button_text_color_1}" FontSize="14"/>
                                <ComboBox Grid.Column="6"  Grid.Row="1" Grid.ColumnSpan="1" Foreground="{DynamicResource Toolbox_button_text_color_1}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" FontFamily="{StaticResource NarutoFont}" Background="{DynamicResource Toolbox_button_background_color_1}" BorderBrush="{DynamicResource Toolbox_button_border_color_1}" BorderThickness="1" SelectedIndex="{Binding EntryType}">
                                    <ComboBoxItem>
                                        <TextBlock Text="{StaticResource m_nus3bankEditor_soundType_1}" Foreground="{DynamicResource Toolbox_button_text_color_1}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" FontFamily="{StaticResource NarutoFont}"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock Text="{StaticResource m_nus3bankEditor_soundType_2}" Foreground="{DynamicResource Toolbox_button_text_color_1}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" FontFamily="{StaticResource NarutoFont}"/>
                                    </ComboBoxItem>
                                    <ComboBoxItem>
                                        <TextBlock Text="{StaticResource m_nus3bankEditor_soundType_3}" Foreground="{DynamicResource Toolbox_button_text_color_1}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" FontFamily="{StaticResource NarutoFont}"/>
                                    </ComboBoxItem>

                                </ComboBox>
                                <Border Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="1" Grid.RowSpan="50" BorderBrush="White" BorderThickness="0,1,0,0"/>
                            </StackPanel>
                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="100"/>
                                </Grid.RowDefinitions>
                                <!-- Regular (по умолчанию видим) -->
                                <ScrollViewer Grid.Row="0" MaxHeight="240" Visibility="{Binding RegularSlotVisibility, UpdateSourceTrigger=PropertyChanged}">
                                    <StackPanel>
                                        <TextBlock Text="Regular entry" FontWeight="Bold"  Margin="0,0,0,8"/>

                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Volume:" Grid.Column="0" VerticalAlignment="Center"/>
                                            <xctk:DoubleUpDown Grid.Column="1"
                                                                MinHeight="30"
                                                                Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                Increment="1"
                                                                VerticalContentAlignment="Center"
                                                                VerticalAlignment="Stretch"
                                                                HorizontalAlignment="Stretch"
                                                                FontFamily="{StaticResource NarutoFont}"
                                                                Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                                                Background="{DynamicResource Toolbox_button_background_color_1}"
                                                                BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                                                BorderThickness="1"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Play Start:" Grid.Column="0" VerticalAlignment="Center"/>
                                            <xctk:IntegerUpDown Grid.Column="1"
                                                                  MinHeight="30"
                                                                  Value="{Binding PlayStart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  Increment="1"
                                                                  VerticalContentAlignment="Center"
                                                                  VerticalAlignment="Stretch"
                                                                  HorizontalAlignment="Stretch"
                                                                  FontFamily="{StaticResource NarutoFont}"
                                                                  Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                                                  Background="{DynamicResource Toolbox_button_background_color_1}"
                                                                  BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                                                  BorderThickness="1"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Play End:" Grid.Column="0" VerticalAlignment="Center"/>
                                            <xctk:DoubleUpDown Grid.Column="1"
                                                          MinHeight="30"
                                                          Value="{Binding PlayEnd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Increment="1"
                                                          VerticalContentAlignment="Center"
                                                          VerticalAlignment="Stretch"
                                                          HorizontalAlignment="Stretch"
                                                          FontFamily="{StaticResource NarutoFont}"
                                                          Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                                          Background="{DynamicResource Toolbox_button_background_color_1}"
                                                          BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                                          BorderThickness="1"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="PlayOffsetX:" Grid.Column="0" VerticalAlignment="Center"/>
                                            <xctk:DoubleUpDown Grid.Column="1"
                                                                MinHeight="30"
                                                                Value="{Binding PlayOffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                Increment="1"
                                                                VerticalContentAlignment="Center"
                                                                VerticalAlignment="Stretch"
                                                                HorizontalAlignment="Stretch"
                                                                FontFamily="{StaticResource NarutoFont}"
                                                                Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                                                Background="{DynamicResource Toolbox_button_background_color_1}"
                                                                BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                                                BorderThickness="1"/>
                                        </Grid>

                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="PlayOffsetY:" Grid.Column="0" VerticalAlignment="Center"/>
                                            <xctk:DoubleUpDown Grid.Column="1"
                                                                MinHeight="30"
                                                                Value="{Binding PlayOffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                Increment="1"
                                                                VerticalContentAlignment="Center"
                                                                VerticalAlignment="Stretch"
                                                                HorizontalAlignment="Stretch"
                                                                FontFamily="{StaticResource NarutoFont}"
                                                                Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                                                Background="{DynamicResource Toolbox_button_background_color_1}"
                                                                BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                                                BorderThickness="1"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Play Delay:" Grid.Column="0" VerticalAlignment="Center"/>
                                            <xctk:DoubleUpDown Grid.Column="1"
MinHeight="30"
Value="{Binding PlayDelay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
Increment="1"
VerticalContentAlignment="Center"
VerticalAlignment="Stretch"
HorizontalAlignment="Stretch"
FontFamily="{StaticResource NarutoFont}"
Foreground="{DynamicResource Toolbox_button_text_color_1}"
Background="{DynamicResource Toolbox_button_background_color_1}"
BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
BorderThickness="1"/>
                                        </Grid>

                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Unknown 1:" Grid.Column="0" VerticalAlignment="Center"/>
                                            <xctk:DoubleUpDown Grid.Column="1"
                                                             MinHeight="30"
                                                             Value="{Binding Unk1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Increment="1"
                                                             VerticalContentAlignment="Center"
                                                             VerticalAlignment="Stretch"
                                                             HorizontalAlignment="Stretch"
                                                             FontFamily="{StaticResource NarutoFont}"
                                                             Foreground="{DynamicResource Toolbox_button_text_color_1}"
                                                             Background="{DynamicResource Toolbox_button_background_color_1}"
                                                             BorderBrush="{DynamicResource Toolbox_button_border_color_1}"
                                                             BorderThickness="1"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Unknown 2:" Grid.Column="0" VerticalAlignment="Center"/>
                                            <xctk:DoubleUpDown Grid.Column="1"
                                                          MinHeight="30"
                                                          Value="{Binding Unk2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Increment="1"
                                                          VerticalContentAlignment="Center"
                                                          VerticalAlignment="Stretch"
                                                          HorizontalAlignment="Stretch"
                                                          FontFamily="{StaticResource NarutoFont}"
                                                          Foreground="{DynamicResource Toolbox_button_text_color_1}"
